generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MatchStatus {
  UPCOMING
  LIVE
  FINISHED
}

enum MatchEventType {
  GOAL
  ASSIST
  YELLOW
  SECOND_YELLOW
  RED
  OWN_GOAL
  PENALTY_MISS
  PENALTY_SAVE
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  fantasyTeams     FantasyTeam[]
  courtAssignments CourtAssignment[]
}

model Player {
  id          String   @id @default(cuid())
  name        String
  team        String
  isGK        Boolean  @default(false)
  imageUrl    String?
  totalPoints Int      @default(0)
  roundPoints Int      @default(0)

  fantasyTeamPlayers FantasyTeamPlayer[]
  matchEvents        MatchEvent[]
}

model FantasyTeam {
  id     String @id @default(cuid())
  name   String
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  players FantasyTeamPlayer[]

  @@index([userId])
}

model FantasyTeamPlayer {
  id            String      @id @default(cuid())
  fantasyTeamId String
  playerId      String
  isCaptain     Boolean     @default(false)
  isSub         Boolean     @default(false)
  fantasyTeam   FantasyTeam @relation(fields: [fantasyTeamId], references: [id], onDelete: Cascade)
  player        Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@unique([fantasyTeamId, playerId])
  @@index([playerId])
}

model Match {
  id                   String      @id @default(cuid())
  teamA                String
  teamB                String
  court                String
  startTime            DateTime
  status               MatchStatus @default(UPCOMING)
  scoreTeamA           Int         @default(0)
  scoreTeamB           Int         @default(0)
  cleanSheetsAppliedAt DateTime?

  events MatchEvent[]

  @@index([status])
  @@index([court])
}

model MatchEvent {
  id       String         @id @default(cuid())
  matchId  String
  playerId String
  type     MatchEventType
  minute   Int
  match    Match          @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player   Player         @relation(fields: [playerId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([playerId])
}

model CourtAssignment {
  id     String @id @default(cuid())
  userId String
  court  String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, court])
  @@index([court])
}

model LeagueSettings {
  id                 String   @id @default("default")
  transferMarketOpen Boolean  @default(true)
  updatedAt          DateTime @updatedAt
}
