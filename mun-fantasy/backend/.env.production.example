# Copy to your host provider’s secret/env UI (do not commit real secrets).
# Your host should set NODE_ENV=production for Node (Render/Railway do this automatically for web services).
NODE_ENV=production
PORT=4000
DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/DB?schema=public
JWT_SECRET=use-a-long-random-string-at-least-32-chars

# Comma-separated browser origins allowed for REST + Socket.IO (your Vercel URL + custom domain).
CLIENT_ORIGIN=https://your-app.vercel.app
TRUST_PROXY=1

# Required in production — creates/updates the admin user on every API deploy/start.
ADMIN_EMAIL=you@yourdomain.com
ADMIN_PASSWORD=choose-a-strong-password

# Required in production — four coordinator logins mapped to courts A–D (same order).
COURT_A_COORD_EMAIL=court-a@yourdomain.com
COURT_B_COORD_EMAIL=court-b@yourdomain.com
COURT_C_COORD_EMAIL=court-c@yourdomain.com
COURT_D_COORD_EMAIL=court-d@yourdomain.com
COORDINATOR_PASSWORD=choose-a-strong-shared-or-distinct-via-DB-rotation
