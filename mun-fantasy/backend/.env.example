DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mun_fantasy?schema=public"
JWT_SECRET="change-this-to-a-long-random-secret-in-production"
PORT=4000
# Comma-separated if you need more than one origin (e.g. Vercel + local).
CLIENT_ORIGIN="http://localhost:5173"
# Set to 1 behind Railway/Render/Fly/nginx so secure cookies and IPs behave correctly.
TRUST_PROXY=0

# Optional overrides (otherwise dev defaults apply on API start — see README).
# ADMIN_EMAIL=
# ADMIN_PASSWORD=
# COURT_A_COORD_EMAIL=
# COURT_B_COORD_EMAIL=
# COURT_C_COORD_EMAIL=
# COURT_D_COORD_EMAIL=
# COORDINATOR_PASSWORD=
